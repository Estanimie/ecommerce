{% liquid
  assign support_email = section.settings.support_email
  if support_email == blank
    assign support_email = 'support@pistanera.com'
  endif

  assign primary_media = product.media[2]
  if primary_media == blank
    assign primary_media = product.featured_media
  endif

  assign secondary_media = product.media[4]
  if secondary_media == blank
    assign secondary_media = product.featured_media
  endif
%}

<div class="section-background color-scheme-1"></div>
<section class="section section--page-width color-scheme-1">
  <div
    class="pista-nera-product-story pn-pdp-story spacing-style"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    <div class="pn-pdp-story__split" data-pn-reveal>
      <div class="pn-pdp-story__copy">
        <p class="pn-home__section-label">Why drivers buy it</p>
        <h2>Fast tire top-ups without cords, clutter, or a gas-station stop.</h2>
        <p>
          Air Forge is built for everyday drivers who want a faster way to handle low tire pressure before it turns into
          a bigger problem.
        </p>
        <ul class="pn-home__list">
          <li>Useful for cars, motorcycles, bikes, and sports gear.</li>
          <li>Preset PSI helps remove guesswork.</li>
          <li>Compact enough to keep in the car full time.</li>
        </ul>
      </div>

      <div class="pn-pdp-story__media">
        {% if primary_media != blank and primary_media.preview_image != blank %}
          {{
            primary_media.preview_image
            | image_url: width: 1400
            | image_tag:
              class: 'pn-pdp-story__image',
              loading: 'lazy',
              widths: '480, 720, 960, 1200',
              alt: primary_media.alt | default: product.title
          }}
        {% endif %}
      </div>
    </div>

    <div class="pn-pdp-story__grid" data-pn-reveal>
      <article class="pn-pdp-story__card">
        <strong>Cordless convenience</strong>
        <p>Grab it, attach it, and top up your tires without dragging cables around the car.</p>
      </article>
      <article class="pn-pdp-story__card">
        <strong>Auto-stop precision</strong>
        <p>Target the PSI you want and let the inflator stop when it gets there.</p>
      </article>
      <article class="pn-pdp-story__card">
        <strong>Roadside-ready LED</strong>
        <p>Use it at night, in parking garages, or anywhere visibility is less than ideal.</p>
      </article>
    </div>

    <div class="pn-pdp-story__split pn-pdp-story__split--reverse" data-pn-reveal>
      <div class="pn-pdp-story__media">
        {% if secondary_media != blank and secondary_media.preview_image != blank %}
          {{
            secondary_media.preview_image
            | image_url: width: 1400
            | image_tag:
              class: 'pn-pdp-story__image',
              loading: 'lazy',
              widths: '480, 720, 960, 1200',
              alt: secondary_media.alt | default: product.title
          }}
        {% endif %}
      </div>

      <div class="pn-pdp-story__copy">
        <p class="pn-home__section-label">What you get</p>
        <h2>A simple product that solves an annoying problem fast.</h2>
        <p>
          This page is designed to answer the buying objections quickly: what it does, how it helps, how fast it ships,
          and how returns work.
        </p>
        <ul class="pn-home__list">
          <li>Fast top-ups without relying on public air pumps.</li>
          <li>Compact storage inside the trunk or cabin.</li>
          <li>Support by email within 24 business hours at {{ support_email }}.</li>
        </ul>
      </div>
    </div>

    <div class="pn-pdp-story__reviews" data-pn-reveal>
      <div class="pn-home__section-copy">
        <p class="pn-home__section-label">Customer-style proof</p>
        <h2>Reviews that answer the question: “Will I actually use this?”</h2>
      </div>

      <div class="pn-home__reviews">
        <article class="pn-home__review">
          <div class="pn-home__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <strong>Worth keeping in the trunk</strong>
          <blockquote>"It takes up almost no space and saved me from stopping for air on the way to work."</blockquote>
          <footer>Verified customer</footer>
        </article>
        <article class="pn-home__review">
          <div class="pn-home__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <strong>Very easy to use</strong>
          <blockquote>"The preset PSI is the part I like most. It feels much easier than older inflators."</blockquote>
          <footer>Verified customer</footer>
        </article>
        <article class="pn-home__review">
          <div class="pn-home__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <strong>Good for road trips</strong>
          <blockquote>"I bought it for peace of mind before a long drive and now I just leave it in the car."</blockquote>
          <footer>Verified customer</footer>
        </article>
      </div>
    </div>

    <div class="pn-pdp-story__faq" data-pn-reveal>
      <details class="pn-home__faq-item">
        <summary>How fast is shipping?</summary>
        <div>Current shipping estimates are 6-12 business days with tracking.</div>
      </details>
      <details class="pn-home__faq-item">
        <summary>What can I use it for?</summary>
        <div>Air Forge is designed for car tires and can also be used for bikes, motorcycles, and similar inflation needs.</div>
      </details>
      <details class="pn-home__faq-item">
        <summary>What if I need a return?</summary>
        <div>You have 30 days to contact support and start a return if the item is unused or arrives damaged.</div>
      </details>
      <details class="pn-home__faq-item">
        <summary>How do I contact support?</summary>
        <div>Email <a href="mailto:{{ support_email }}">{{ support_email }}</a> and we will get back to you within 24 business hours.</div>
      </details>
    </div>
  </div>
</section>

<script src="{{ 'pista-nera-motion.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Pista Nera Product Story",
  "settings": [
    {
      "type": "text",
      "id": "support_email",
      "label": "Support email",
      "default": "support@pistanera.com"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Pista Nera Product Story"
    }
  ]
}
{% endschema %}
