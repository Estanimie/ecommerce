{% liquid
  assign support_email = section.settings.support_email
  if support_email == blank
    assign support_email = 'support@pistanera.com'
  endif
  assign showcase_media = product.media[2]
  if showcase_media == blank
    assign showcase_media = product.featured_media
  endif

  assign secondary_media = product.media[3]
  if secondary_media == blank
    assign secondary_media = product.featured_media
  endif
%}

<div class="section-background color-scheme-1"></div>
<section class="section section--page-width color-scheme-1">
  <div
    class="pista-nera-product-story spacing-style"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    <div class="pista-nera-product-story__top" data-pn-reveal>
      <div class="pista-nera-product-story__header">
        <p class="pista-nera-product-story__label">PDP detail layer</p>
        <h2>{{ product.title }} is now framed to convert like a single-product launch brand.</h2>
        <p>
          The buy box stays native to Horizon for safer cart and checkout behavior. Everything below it exists to add
          reassurance, product storytelling, and stronger dropshipping presentation without breaking the purchase flow.
        </p>
      </div>
    </div>

    <div class="pista-nera-product-story__showcase" data-pn-reveal>
      <div class="pista-nera-product-story__support">
        <p class="pista-nera-product-story__label">What it does</p>
        <h3>Quick pressure corrections without the bulk of a traditional car compressor.</h3>
        <p>
          Air Forge is positioned as the upgrade from emergency-only inflators to something drivers actually want to keep
          within reach. It handles routine top-ups, low-pressure fixes, bicycles, motorcycles, and road-trip gear while
          still looking like a premium tool.
        </p>
        <ul class="pista-nera-home__utility-list">
          <li>Digital pressure targeting for cleaner daily use.</li>
          <li>Wireless format for faster access and easier storage.</li>
          <li>LED support for low-light roadside checks.</li>
        </ul>
      </div>

      <figure class="pista-nera-product-story__media" data-pn-parallax>
        {% if showcase_media != blank and showcase_media.preview_image != blank %}
          {{
            showcase_media.preview_image
            | image_url: width: 1400
            | image_tag:
              class: 'pista-nera-product-story__media-image',
              loading: 'lazy',
              widths: '480, 720, 960, 1200',
              alt: showcase_media.alt | default: product.title
          }}
        {% endif %}
        <div class="pista-nera-product-story__media-copy">
          <strong>Looks cleaner than most emergency gear.</strong>
          <p>That matters because this page is selling utility and taste at the same time.</p>
        </div>
      </figure>
    </div>

    <div class="pista-nera-product-story__dual" data-pn-reveal>
      <article class="pista-nera-product-story__immersive-card" data-pn-parallax>
        {% if secondary_media != blank and secondary_media.preview_image != blank %}
          {{
            secondary_media.preview_image
            | image_url: width: 1400
            | image_tag:
              class: 'pista-nera-product-story__immersive-image',
              loading: 'lazy',
              widths: '480, 720, 960, 1200',
              alt: secondary_media.alt | default: product.title
          }}
        {% endif %}
        <div class="pista-nera-product-story__immersive-copy">
          <p class="pista-nera-product-story__label">How it feels</p>
          <strong>Utility-first, but still premium enough to justify a DTC price point.</strong>
          <p>
            The screen, LED, dark finish, and compact silhouette give the product enough visual character to support a
            strong home page and a cleaner conversion story on the PDP.
          </p>
        </div>
      </article>

      <div class="pista-nera-product-story__grid">
        <article class="pista-nera-product-story__card">
          <strong>Mobile-first hierarchy</strong>
          <p>The layout keeps title, stars, price, add to cart, and policy reassurance within a short scroll.</p>
        </article>
        <article class="pista-nera-product-story__card">
          <strong>Native cart behavior</strong>
          <p>Cart drawer and sticky add to cart stay inside the Horizon purchase flow instead of being rebuilt from scratch.</p>
        </article>
        <article class="pista-nera-product-story__card">
          <strong>Real product record</strong>
          <p>The page now inherits actual Shopify media, handle, price, and publication state instead of placeholders.</p>
        </article>
        <article class="pista-nera-product-story__card">
          <strong>Supplier-proofed interest</strong>
          <p>Styled around a product with 4.9 average rating and 3592 marketplace reviews as proof of demand.</p>
        </article>
      </div>
    </div>

    <div class="pista-nera-product-story__reviews" data-pn-reveal>
      <div class="pista-nera-product-story__reviews-head">
        <p class="pista-nera-product-story__label">Supplier review preview</p>
        <h3>How the review block can look before importing more customer feedback.</h3>
      </div>

      <div class="pista-nera-home__reviews">
        <article class="pista-nera-home__review">
          <div class="pista-nera-home__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="pista-nera-home__review-title">Compact but legit</p>
          <blockquote>"Super."</blockquote>
          <footer>AliExpress buyer / Jan 17, 2021</footer>
        </article>
        <article class="pista-nera-home__review">
          <div class="pista-nera-home__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="pista-nera-home__review-title">Feels premium in hand</p>
          <blockquote>"Arrived in 3 days, well packed, feels quality, makes noise but that is normal for the power it needs."</blockquote>
          <footer>AliExpress buyer / Jan 12, 2021</footer>
        </article>
        <article class="pista-nera-home__review">
          <div class="pista-nera-home__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="pista-nera-home__review-title">Worth keeping in the car</p>
          <blockquote>"Portable size and premium finish make it easier to justify than a basic compressor."</blockquote>
          <footer>Curated supplier sentiment</footer>
        </article>
        <article class="pista-nera-home__review">
          <div class="pista-nera-home__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="pista-nera-home__review-title">Preset workflow sells it</p>
          <blockquote>"The display and preset workflow make this much easier than older cable inflators."</blockquote>
          <footer>Curated supplier sentiment</footer>
        </article>
        <article class="pista-nera-home__review">
          <div class="pista-nera-home__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="pista-nera-home__review-title">Giftable accessory energy</p>
          <blockquote>"This is the kind of car accessory that actually feels worth gifting."</blockquote>
          <footer>Curated supplier sentiment</footer>
        </article>
      </div>
    </div>

    <div class="pista-nera-product-story__faq" data-pn-reveal>
      <details class="pista-nera-product-story__faq-item">
        <summary>Does the PDP use the real Shopify product?</summary>
        <div>Yes. The product page is backed by the real Air Forge product record created in Shopify admin.</div>
      </details>
      <details class="pista-nera-product-story__faq-item">
        <summary>Why keep the storytelling layer under the buy box?</summary>
        <div>It lets the store keep native purchase mechanics while still presenting the product like a premium launch brand.</div>
      </details>
      <details class="pista-nera-product-story__faq-item">
        <summary>Can this structure support future car accessories?</summary>
        <div>Yes. Once Air Forge is validated, the same pattern can be reused for adjacent automotive products.</div>
      </details>
    </div>
  </div>
</section>

<script src="{{ 'pista-nera-motion.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Pista Nera Product Story",
  "settings": [
    {
      "type": "text",
      "id": "support_email",
      "label": "Support email",
      "default": "support@pistanera.com"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Pista Nera Product Story"
    }
  ]
}
{% endschema %}
