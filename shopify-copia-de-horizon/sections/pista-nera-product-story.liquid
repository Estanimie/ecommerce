{% liquid
  assign support_email = section.settings.support_email
  if support_email == blank
    assign support_email = 'support@pistanera.com'
  endif

  assign showcase_media = product.media[2]
  if showcase_media == blank
    assign showcase_media = product.featured_media
  endif
%}

<div class="section-background color-scheme-1"></div>
<section class="section section--page-width color-scheme-1">
  <div
    class="pista-nera-product-story spacing-style"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    <div class="pista-nera-product-story__top">
      <div class="pista-nera-product-story__header">
        <p class="pista-nera-product-story__label">PDP detail layer</p>
        <h2>{{ product.title }} is framed to convert like a modern single-product storefront.</h2>
        <p>
          The buy box stays native to Horizon for safer cart and checkout behavior, while the sections below handle the
          premium storytelling, reassurance, and supplier-review formatting that the product page needs after the first CTA.
        </p>
      </div>

      <div class="pista-nera-product-story__policy-grid">
        <article class="pista-nera-product-story__policy-card">
          <strong>Tracked shipping</strong>
          <p>Estimated delivery window: 6 to 10 business days for the current launch configuration.</p>
        </article>
        <article class="pista-nera-product-story__policy-card">
          <strong>30-day returns</strong>
          <p>Unused items can be returned in original condition within the return period.</p>
        </article>
        <article class="pista-nera-product-story__policy-card">
          <strong>Direct support</strong>
          <p><a href="mailto:{{ support_email }}">{{ support_email }}</a> stays visible throughout the funnel.</p>
        </article>
      </div>
    </div>

    <div class="pista-nera-product-story__showcase">
      <div class="pista-nera-product-story__support">
        <p class="pista-nera-product-story__label">What it does</p>
        <h3>Quick pressure corrections without the bulk of a traditional car compressor.</h3>
        <p>
          Air Forge is positioned as the upgrade from “emergency-only” inflators to something drivers actually want to keep
          within reach. It handles routine top-ups, low-pressure fixes, bicycles, motorcycles, and road-trip gear while
          still looking like a premium tool.
        </p>
        <ul class="pista-nera-home__utility-list">
          <li>Digital pressure targeting for cleaner daily use.</li>
          <li>Wireless format for faster access and easier storage.</li>
          <li>LED support for low-light roadside checks.</li>
        </ul>
      </div>

      <figure class="pista-nera-product-story__media">
        {% if showcase_media != blank and showcase_media.preview_image != blank %}
          {{
            showcase_media.preview_image
            | image_url: width: 1400
            | image_tag:
              class: 'pista-nera-product-story__media-image',
              loading: 'lazy',
              widths: '480, 720, 960, 1200',
              alt: showcase_media.alt | default: product.title
          }}
        {% endif %}
        <div class="pista-nera-product-story__media-copy">
          <strong>Looks cleaner than most emergency gear.</strong>
          <p>That matters because this page is selling utility and taste at the same time.</p>
        </div>
      </figure>
    </div>

    <div class="pista-nera-product-story__grid">
      <article class="pista-nera-product-story__card">
        <strong>Mobile-first hierarchy</strong>
        <p>The layout keeps title, stars, price, add to cart, and policy reassurance within a short scroll.</p>
      </article>
      <article class="pista-nera-product-story__card">
        <strong>Native cart behavior</strong>
        <p>Cart drawer and sticky add to cart stay in the Horizon purchase flow instead of being rebuilt from scratch.</p>
      </article>
      <article class="pista-nera-product-story__card">
        <strong>Real product record</strong>
        <p>The page now inherits actual Shopify media, handle, price, and publication state instead of placeholder content.</p>
      </article>
      <article class="pista-nera-product-story__card">
        <strong>Supplier-proofed interest</strong>
        <p>We are styling around a product with 4.9 average rating and 3592 marketplace reviews as proof of demand.</p>
      </article>
    </div>

    <div class="pista-nera-product-story__reviews">
      <div class="pista-nera-product-story__reviews-head">
        <p class="pista-nera-product-story__label">Supplier review preview</p>
        <h3>How the review block can look before importing more customer feedback.</h3>
      </div>

      <div class="pista-nera-home__reviews">
        <article class="pista-nera-home__review">
          <div class="pista-nera-home__stars">★★★★★</div>
          <blockquote>“super”</blockquote>
          <footer>AliExpress buyer / Jan 17, 2021</footer>
        </article>
        <article class="pista-nera-home__review">
          <div class="pista-nera-home__stars">★★★★★</div>
          <blockquote>
            “Arrived in 3 days, well packed, feels quality, makes noise but that is normal for the power it needs.”
          </blockquote>
          <footer>AliExpress buyer / Jan 12, 2021</footer>
        </article>
        <article class="pista-nera-home__review">
          <div class="pista-nera-home__stars">★★★★★</div>
          <blockquote>“Portable size and premium finish make it easier to justify than a basic compressor.”</blockquote>
          <footer>Curated supplier sentiment</footer>
        </article>
      </div>
    </div>

    <div class="pista-nera-product-story__faq">
      <details class="pista-nera-product-story__faq-item">
        <summary>Does the PDP use the real Shopify product now?</summary>
        <div>Yes. The product page is now backed by the real Air Forge product record created in Shopify admin.</div>
      </details>
      <details class="pista-nera-product-story__faq-item">
        <summary>Why keep a separate storytelling section under the buy box?</summary>
        <div>It lets the store keep native purchase mechanics while still presenting the product like a premium launch brand.</div>
      </details>
      <details class="pista-nera-product-story__faq-item">
        <summary>Can this structure support future car accessories?</summary>
        <div>Yes. Once Air Forge is validated, the same pattern can be reused for adjacent automotive products.</div>
      </details>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Pista Nera Product Story",
  "settings": [
    {
      "type": "text",
      "id": "support_email",
      "label": "Support email",
      "default": "support@pistanera.com"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Pista Nera Product Story"
    }
  ]
}
{% endschema %}
