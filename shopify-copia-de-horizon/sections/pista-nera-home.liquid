{% liquid
  assign featured_product = section.settings.featured_product
  if featured_product == blank
    assign featured_product = all_products['air-forge-portable-tire-inflator']
  endif

  assign support_email = section.settings.support_email
  if support_email == blank
    assign support_email = 'support@pistanera.com'
  endif

  assign product_url = routes.all_products_collection_url
  assign current_variant = nil
  assign hero_media = nil
  assign problem_media = nil
  assign final_media = nil

  if featured_product != blank
    assign product_url = featured_product.url
    assign current_variant = featured_product.selected_or_first_available_variant
    assign hero_media = featured_product.featured_media
    assign problem_media = featured_product.media[2]
    if problem_media == blank
      assign problem_media = featured_product.media[1]
    endif
    assign final_media = featured_product.media[4]
    if final_media == blank
      assign final_media = featured_product.featured_media
    endif
  endif

  assign compare_price = nil
  assign current_price = nil
  if current_variant != blank
    assign compare_price = current_variant.compare_at_price
    assign current_price = current_variant.price
  endif
%}

<div class="section-background color-scheme-1"></div>
<section class="section section--page-width color-scheme-1">
  <div
    class="pista-nera-home pn-home spacing-style"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    <div class="pn-home__hero">
      <div class="pn-home__hero-copy" data-pn-reveal>
        <p class="pn-home__eyebrow">{{ section.settings.hero_badge }}</p>
        <h1 class="pn-home__title">{{ section.settings.hero_headline }}</h1>
        <p class="pn-home__subtitle">{{ section.settings.hero_subheadline }}</p>

        <div class="pn-home__cta">
          <a href="{{ product_url }}" class="button">{{ section.settings.cta_label }}</a>
        </div>

        <ul class="pn-home__trust-row">
          <li>Free tracked shipping</li>
          <li>30-day guarantee</li>
          <li>Secure checkout</li>
        </ul>
      </div>

      <div class="pn-home__hero-media" data-pn-reveal>
        <div class="pn-home__hero-card">
          {% if hero_media != blank and hero_media.preview_image != blank %}
            {{
              hero_media.preview_image
              | image_url: width: 1440
              | image_tag:
                class: 'pn-home__hero-image',
                loading: 'eager',
                widths: '480, 720, 960, 1200, 1440',
                alt: hero_media.alt | default: featured_product.title
            }}
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'pn-home__hero-placeholder' }}
          {% endif %}

          {% if current_variant != blank %}
            <div class="pn-home__hero-offer">
              <span class="pn-home__hero-offer-label">Limited launch offer</span>
              <strong>{{ current_price | money }}</strong>
              {% if compare_price > current_price %}
                <s>{{ compare_price | money }}</s>
              {% endif %}
              <small>Limited stock for this batch</small>
            </div>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="pn-home__problem">
      <div class="pn-home__section-copy" data-pn-reveal>
        <p class="pn-home__section-label">The problem</p>
        <h2>{{ section.settings.problem_heading }}</h2>
        <p>{{ section.settings.problem_body }}</p>
        <ul class="pn-home__list">
          <li>Gas-station pumps are inconsistent, busy, or out of order.</li>
          <li>Bulky wired compressors are annoying to keep in the car.</li>
          <li>Low tire pressure always seems to show up when you are already in a rush.</li>
        </ul>
      </div>

      <div class="pn-home__problem-media" data-pn-reveal>
        {% if problem_media != blank and problem_media.preview_image != blank %}
          {{
            problem_media.preview_image
            | image_url: width: 1200
            | image_tag:
              class: 'pn-home__problem-image',
              loading: 'lazy',
              widths: '400, 640, 900, 1200',
              alt: problem_media.alt | default: featured_product.title
          }}
        {% endif %}
        <div class="pn-home__problem-card">
          <strong>Made for commuters, road trips, and everyday drivers.</strong>
          <span>Keep it in the car and handle pressure alerts before they turn into delays.</span>
        </div>
      </div>
    </div>

    <div class="pn-home__section" data-pn-reveal>
      <div class="pn-home__section-copy">
        <p class="pn-home__section-label">Benefits</p>
        <h2>Everything the customer needs to understand in a few seconds.</h2>
      </div>

      <div class="pn-home__benefits">
        {% assign benefit_count = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'benefit' %}
            {% assign benefit_count = benefit_count | plus: 1 %}
            <article class="pn-home__benefit" {{ block.shopify_attributes }}>
              <span class="pn-home__icon">
                {% case block.settings.icon %}
                  {% when 'gauge' %}
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4a9 9 0 1 0 9 9h-2a7 7 0 1 1-2.05-4.95L14 11l1.41 1.41L20.83 7A8.95 8.95 0 0 0 12 4Z"/></svg>
                  {% when 'bolt' %}
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13 2 5 14h5l-1 8 8-12h-5l1-8Z"/></svg>
                  {% when 'shield' %}
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 9.4 8 10 4.6-.6 8-5 8-10V5l-8-3Zm0 18c-3.2-.6-6-4-6-8.3V6.4l6-2.2 6 2.2v5.3c0 4.3-2.8 7.7-6 8.3Z"/></svg>
                  {% when 'lamp' %}
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 21h6v-1H9v1Zm3-19a7 7 0 0 0-4 12.7V17h8v-2.3A7 7 0 0 0 12 2Zm2 11.6-.5.3V15h-3v-1.1l-.5-.3A5 5 0 1 1 14 13.6Z"/></svg>
                  {% else %}
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 5h14v14H5z"/></svg>
                {% endcase %}
              </span>
              <strong>{{ block.settings.title }}</strong>
              <p>{{ block.settings.body }}</p>
            </article>
          {% endif %}
        {% endfor %}

        {% if benefit_count == 0 %}
          <article class="pn-home__benefit">
            <span class="pn-home__icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4a9 9 0 1 0 9 9h-2a7 7 0 1 1-2.05-4.95L14 11l1.41 1.41L20.83 7A8.95 8.95 0 0 0 12 4Z"/></svg></span>
            <strong>Fast pressure top-ups</strong>
            <p>Fix low tire pressure in minutes without driving around for a working air pump.</p>
          </article>
          <article class="pn-home__benefit">
            <span class="pn-home__icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13 2 5 14h5l-1 8 8-12h-5l1-8Z"/></svg></span>
            <strong>Cordless and compact</strong>
            <p>Keep it in your trunk or back seat without cable clutter.</p>
          </article>
          <article class="pn-home__benefit">
            <span class="pn-home__icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 9.4 8 10 4.6-.6 8-5 8-10V5l-8-3Zm0 18c-3.2-.6-6-4-6-8.3V6.4l6-2.2 6 2.2v5.3c0 4.3-2.8 7.7-6 8.3Z"/></svg></span>
            <strong>Auto-stop confidence</strong>
            <p>Set your target PSI and stop overfilling or second-guessing.</p>
          </article>
          <article class="pn-home__benefit">
            <span class="pn-home__icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 21h6v-1H9v1Zm3-19a7 7 0 0 0-4 12.7V17h8v-2.3A7 7 0 0 0 12 2Zm2 11.6-.5.3V15h-3v-1.1l-.5-.3A5 5 0 1 1 14 13.6Z"/></svg></span>
            <strong>Night-ready LED</strong>
            <p>Check and top up your tires even in low light or roadside situations.</p>
          </article>
        {% endif %}
      </div>
    </div>

    <div class="pn-home__section" data-pn-reveal>
      <div class="pn-home__section-copy">
        <p class="pn-home__section-label">How it works</p>
        <h2>Three simple steps and you are back on the road.</h2>
      </div>

      <div class="pn-home__steps">
        {% assign step_count = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'step' %}
            {% assign step_count = step_count | plus: 1 %}
            <article class="pn-home__step" {{ block.shopify_attributes }}>
              <span class="pn-home__step-number">{{ forloop.index }}</span>
              <strong>{{ block.settings.title }}</strong>
              <p>{{ block.settings.body }}</p>
            </article>
          {% endif %}
        {% endfor %}

        {% if step_count == 0 %}
          <article class="pn-home__step">
            <span class="pn-home__step-number">1</span>
            <strong>Set the target PSI</strong>
            <p>Choose the pressure you want before you start.</p>
          </article>
          <article class="pn-home__step">
            <span class="pn-home__step-number">2</span>
            <strong>Attach and press start</strong>
            <p>Connect the hose to the tire and let Air Forge do the work.</p>
          </article>
          <article class="pn-home__step">
            <span class="pn-home__step-number">3</span>
            <strong>Stop and store it</strong>
            <p>Once it hits the target pressure, put it back in the car for the next time you need it.</p>
          </article>
        {% endif %}
      </div>
    </div>

    <div class="pn-home__section" data-pn-reveal>
      <div class="pn-home__section-copy">
        <p class="pn-home__section-label">Social proof</p>
        <h2>Real-world style reviews that reduce hesitation.</h2>
      </div>

      <div class="pn-home__reviews">
        {% assign review_count = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'review' %}
            {% assign review_count = review_count | plus: 1 %}
            <article class="pn-home__review" {{ block.shopify_attributes }}>
              <div class="pn-home__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              <strong>{{ block.settings.title }}</strong>
              <blockquote>"{{ block.settings.body }}"</blockquote>
              <footer>{{ block.settings.author }}</footer>
            </article>
          {% endif %}
        {% endfor %}

        {% if review_count == 0 %}
          <article class="pn-home__review">
            <div class="pn-home__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <strong>Exactly what I wanted in the car</strong>
            <blockquote>"Small enough to keep in the trunk and way easier than stopping at a gas station."</blockquote>
            <footer>Verified customer</footer>
          </article>
          <article class="pn-home__review">
            <div class="pn-home__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <strong>Super easy to use</strong>
            <blockquote>"Set the PSI, hit start, and it stops on its own. That was the selling point for me."</blockquote>
            <footer>Verified customer</footer>
          </article>
          <article class="pn-home__review">
            <div class="pn-home__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <strong>Great for road trips</strong>
            <blockquote>"I keep it in the car all the time now. It is one of those products you are glad to have when you need it."</blockquote>
            <footer>Verified customer</footer>
          </article>
        {% endif %}
      </div>
    </div>

    <div class="pn-home__offer" data-pn-reveal>
      <div class="pn-home__section-copy">
        <p class="pn-home__section-label">{{ section.settings.offer_badge }}</p>
        <h2>{{ section.settings.offer_heading }}</h2>
        <p>{{ section.settings.offer_body }}</p>
      </div>

      <div class="pn-home__offer-card">
        {% if current_variant != blank %}
          <div class="pn-home__offer-price">
            {% if compare_price > current_price %}
              <s>{{ compare_price | money }}</s>
            {% endif %}
            <strong>{{ current_price | money }}</strong>
          </div>
        {% endif %}

        <ul class="pn-home__list pn-home__list--tight">
          <li>Free tracked shipping in 6-12 business days.</li>
          <li>30-day money-back guarantee.</li>
          <li>Secure checkout and customer support within 24 business hours.</li>
        </ul>

        <div class="pn-home__cta">
          <a href="{{ product_url }}" class="button">{{ section.settings.cta_label }}</a>
        </div>
      </div>
    </div>

    <div class="pn-home__guarantee" data-pn-reveal>
      <div class="pn-home__section-copy">
        <p class="pn-home__section-label">Guarantee</p>
        <h2>{{ section.settings.guarantee_heading }}</h2>
        <p>{{ section.settings.guarantee_body }}</p>
      </div>

      <div class="pn-home__guarantee-grid">
        <article class="pn-home__mini-card">
          <strong>Secure checkout</strong>
          <p>Your order goes through Shopify checkout with card protection and encrypted payment processing.</p>
        </article>
        <article class="pn-home__mini-card">
          <strong>Tracked delivery</strong>
          <p>You will receive tracking as soon as your order is dispatched.</p>
        </article>
        <article class="pn-home__mini-card">
          <strong>Simple support</strong>
          <p>Questions about shipping or returns? Email <a href="mailto:{{ support_email }}">{{ support_email }}</a>.</p>
        </article>
      </div>
    </div>

    <div class="pn-home__final" data-pn-reveal>
      <div class="pn-home__final-copy">
        <p class="pn-home__section-label">Final call to action</p>
        <h2>{{ section.settings.final_heading }}</h2>
        <p>{{ section.settings.final_body }}</p>
        <div class="pn-home__cta">
          <a href="{{ product_url }}" class="button">{{ section.settings.cta_label }}</a>
        </div>
      </div>

      <div class="pn-home__final-media">
        {% if final_media != blank and final_media.preview_image != blank %}
          {{
            final_media.preview_image
            | image_url: width: 1200
            | image_tag:
              class: 'pn-home__final-image',
              loading: 'lazy',
              widths: '400, 640, 900, 1200',
              alt: final_media.alt | default: featured_product.title
          }}
        {% endif %}
      </div>
    </div>

    {% if current_variant != blank %}
      <div class="pn-home__sticky-cta" aria-label="Sticky buy now">
        <div class="pn-home__sticky-price">
          {% if compare_price > current_price %}
            <s>{{ compare_price | money }}</s>
          {% endif %}
          <strong>{{ current_price | money }}</strong>
        </div>
        <a href="{{ product_url }}" class="button">{{ section.settings.cta_label }}</a>
      </div>
    {% endif %}
  </div>
</section>

<script src="{{ 'pista-nera-motion.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Pista Nera Home",
  "settings": [
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured product"
    },
    {
      "type": "text",
      "id": "support_email",
      "label": "Support email",
      "default": "support@pistanera.com"
    },
    {
      "type": "text",
      "id": "hero_badge",
      "label": "Hero badge",
      "default": "Limited launch offer"
    },
    {
      "type": "text",
      "id": "hero_headline",
      "label": "Hero headline",
      "default": "Inflate Your Tires in Minutes Without Cords or Gas Station Stops"
    },
    {
      "type": "textarea",
      "id": "hero_subheadline",
      "label": "Hero subheadline",
      "default": "Keep a cordless inflator in your car so low pressure never turns into a delay, roadside hassle, or a last-minute stop for air."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Buy Now"
    },
    {
      "type": "text",
      "id": "problem_heading",
      "label": "Problem heading",
      "default": "Low tire pressure always shows up at the worst time."
    },
    {
      "type": "textarea",
      "id": "problem_body",
      "label": "Problem body",
      "default": "Most drivers notice it when they are already late, far from a reliable air pump, or stuck dealing with an old compressor and messy cables."
    },
    {
      "type": "text",
      "id": "offer_badge",
      "label": "Offer badge",
      "default": "Launch offer"
    },
    {
      "type": "text",
      "id": "offer_heading",
      "label": "Offer heading",
      "default": "Get Air Forge now with free tracked shipping."
    },
    {
      "type": "textarea",
      "id": "offer_body",
      "label": "Offer body",
      "default": "Launch pricing is live now. Stock is limited for this batch and the current offer can end without notice."
    },
    {
      "type": "text",
      "id": "guarantee_heading",
      "label": "Guarantee heading",
      "default": "30-day money-back guarantee"
    },
    {
      "type": "textarea",
      "id": "guarantee_body",
      "label": "Guarantee body",
      "default": "Try Air Forge risk-free. If it arrives damaged or you change your mind within 30 days, contact support and we will help you start a return."
    },
    {
      "type": "text",
      "id": "final_heading",
      "label": "Final CTA heading",
      "default": "Be ready before the next low-pressure warning."
    },
    {
      "type": "textarea",
      "id": "final_body",
      "label": "Final CTA body",
      "default": "Air Forge gives you a fast, simple way to top up your tires without cords, clutter, or gas-station stops."
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "limit": 5,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "gauge",
          "options": [
            { "value": "gauge", "label": "Gauge" },
            { "value": "bolt", "label": "Bolt" },
            { "value": "shield", "label": "Shield" },
            { "value": "lamp", "label": "Lamp" }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Fast pressure top-ups"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Fix low tire pressure in minutes without driving around for a working air pump."
        }
      ]
    },
    {
      "type": "step",
      "name": "Step",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Set the target PSI"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Choose the pressure you want before you start."
        }
      ]
    },
    {
      "type": "review",
      "name": "Review",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Exactly what I wanted in the car"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Review body",
          "default": "Small enough to keep in the trunk and way easier than stopping at a gas station."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Verified customer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pista Nera Home",
      "blocks": [
        { "type": "benefit" },
        { "type": "benefit" },
        { "type": "benefit" },
        { "type": "benefit" },
        { "type": "step" },
        { "type": "step" },
        { "type": "step" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
