{% liquid
  assign support_email = section.settings.support_email
  if support_email == blank
    assign support_email = 'support@pistanera.com'
  endif
%}

<div class="section-background color-scheme-1"></div>
<section class="section section--page-width color-scheme-1">
  <div
    class="pista-nera-product-policies pn-pdp-policies spacing-style"
    style="{% render 'spacing-style', settings: section.settings %}"
    data-pn-reveal
  >
    <article class="pn-pdp-policies__card">
      <strong>Free tracked shipping</strong>
      <p>Estimated delivery in 6-12 business days for the current batch.</p>
    </article>
    <article class="pn-pdp-policies__card">
      <strong>30-day money-back guarantee</strong>
      <p>If it arrives damaged or you change your mind, contact us within 30 days.</p>
    </article>
    <article class="pn-pdp-policies__card">
      <strong>Secure checkout and support</strong>
      <p>Checkout is protected by Shopify. Questions? Email {{ support_email }}.</p>
    </article>
  </div>
</section>

{% schema %}
{
  "name": "Pista Nera Policies",
  "settings": [
    {
      "type": "text",
      "id": "support_email",
      "label": "Support email",
      "default": "support@pistanera.com"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 28
    }
  ],
  "presets": []
}
{% endschema %}
